    <!-- Terminal Animation Script -->
    <script>
      const demoLines = [
        { ts: '[09:14]', agent: 'Agent:', msg: 'checking usage for sarah@company.com this billing period', type: 'agent' },
        { ts: '[09:14]', agent: 'Agent:', msg: '47 operations this week — tracking ahead of monthly average', type: 'agent' },
        { ts: '[09:14]', agent: 'Agent:', msg: 'projected: 3,200 units by month-end (Pro tier: 3,000)', type: 'agent' },
        { ts: '[09:14]', agent: 'Agent:', msg: '⚠️  user approaching tier cliff — $50 → $100 forced upgrade', type: 'warning' },
        { ts: '[09:14]', agent: 'Agent:', msg: 'calculating alternative: consumption billing @ $0.007/unit', type: 'agent' },
        { ts: '[09:14]', agent: 'Agent:', msg: '→ 3,200 units × $0.007 = $22.40 vs $100 subscription tier', type: 'agent' },
        { ts: '[09:14]', agent: 'Agent:', msg: '✓ sending intervention email with consumption option', type: 'success' },
        { ts: '', agent: '', msg: '', type: 'pause' },
        { ts: '[09:47]', agent: 'User:', msg: 'clicked "Switch to pay-as-you-go this month"', type: 'user' },
        { ts: '[09:47]', agent: 'Agent:', msg: '✓ billing mode updated: consumption override active', type: 'success' },
        { ts: '[09:47]', agent: 'System:', msg: '$77.60 saved. Customer retained.', type: 'highlight' },
        { ts: '', agent: '', msg: '', type: 'pause' },
        { ts: '[10:23]', agent: 'Agent:', msg: 'monitoring 247 users | 3 tier-cliff risks detected today', type: 'agent' },
        { ts: '[10:23]', agent: 'Agent:', msg: 'avg. intervention savings: $34.20 per caught user', type: 'agent' },
      ];

      let lineIndex = 0;
      const terminalContent = document.getElementById('terminal-content');
      const terminalContainer = document.getElementById('terminal');

      function getTimestampClass() {
        return 'text-[#52525B]';
      }

      function getAgentClass(type) {
        switch(type) {
          case 'agent': return 'text-[#3B82F6]';
          case 'warning': return 'text-[#F59E0B]';
          case 'success': return 'text-[#10B981]';
          case 'user': return 'text-[#A1A1AA]';
          case 'highlight': return 'text-[#00B8D9] font-medium';
          default: return 'text-[#A1A1AA]';
        }
      }

      function getMessageClass(type) {
        switch(type) {
          case 'warning': return 'text-[#F59E0B]';
          case 'success': return 'text-[#10B981]';
          case 'user': return 'text-[#A1A1AA]';
          case 'highlight': return 'text-[#00B8D9] font-medium';
          default: return 'text-[#A1A1AA]';
        }
      }

      function typeLine() {
        if (lineIndex >= demoLines.length) {
          // Restart after a pause
          setTimeout(() => {
            terminalContent.innerHTML = '';
            lineIndex = 0;
            typeLine();
          }, 5000);
          return;
        }

        const line = demoLines[lineIndex];

        if (line.type === 'pause') {
          lineIndex++;
          setTimeout(typeLine, 800);
          return;
        }

        const lineDiv = document.createElement('div');
        lineDiv.className = 'terminal-line flex gap-2';
        lineDiv.style.animationDelay = '0s';

        const tsSpan = document.createElement('span');
        tsSpan.className = getTimestampClass();
        tsSpan.textContent = line.ts;

        const agentSpan = document.createElement('span');
        agentSpan.className = getAgentClass(line.type);
        agentSpan.textContent = line.agent;

        const msgSpan = document.createElement('span');
        msgSpan.className = getMessageClass(line.type);

        lineDiv.appendChild(tsSpan);
        if (line.agent) {
          lineDiv.appendChild(agentSpan);
        }
        lineDiv.appendChild(msgSpan);

        terminalContent.appendChild(lineDiv);

        // Typewriter effect for the message
        let charIndex = 0;
        const typeChar = () => {
          if (charIndex < line.msg.length) {
            msgSpan.textContent += line.msg[charIndex];
            charIndex++;
            setTimeout(typeChar, 15);
          } else {
            lineIndex++;
            setTimeout(typeLine, line.type === 'pause' ? 500 : 400);
          }
        };

        // Scroll to bottom
        terminalContainer.scrollTop = terminalContainer.scrollHeight;

        typeChar();
      }

      // Start the animation when page loads
      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(typeLine, 500);
      });
    </script>
