---
// Drip Landing Page — B2B2C Middleware Positioning
// Locus Aesthetic Edition: Dark theme, animated terminal demo
// Target: SaaS founders, CTOs, product teams
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Drip — Bridge the gap between subscription tiers and consumption reality. Pay-as-you-drink billing for modern SaaS." />
    <title>Drip — Your Subscription Model Is Leaking Revenue. Drip Plugs the Holes.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Space Grotesk', sans-serif; }
    </style>
  </head>
  <body class="antialiased bg-[#0A0A0A] text-white">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#0A0A0A]/80 backdrop-blur-xl border-b border-[#1F1F1F]">
      <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-[#00B8D9] rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-[#0A0A0A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 2v20M2 12h20"/>
            </svg>
          </div>
          <span class="font-semibold text-lg tracking-tight">drip</span>
        </div>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-[#A1A1AA]">
          <a href="#problem" class="hover:text-white transition-colors">The Problem</a>
          <a href="#how-it-works" class="hover:text-white transition-colors">How It Works</a>
          <a href="#integration" class="hover:text-white transition-colors">Integration</a>
          <a href="#early-access" class="hover:text-white transition-colors">Early Access</a>
        </div>
        <div class="flex items-center gap-4">
          <a href="#early-access" class="bg-white text-[#0A0A0A] px-4 py-2 rounded-md text-sm font-medium hover:bg-[#A1A1AA] transition-colors">
            Get Early Access
          </a>
        </div>
      </nav>
    </header>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 lg:pt-40 lg:pb-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center mb-12">
          <h1 class="text-4xl lg:text-6xl font-semibold tracking-tight text-white leading-[1.1] mb-6">
            Your subscription model is<br/>
            <span class="text-gradient-cyan">leaking revenue.</span><br/>
            <span class="text-white">Drip plugs the holes.</span>
          </h1>
          <p class="text-lg lg:text-xl text-[#A1A1AA] leading-relaxed max-w-2xl mx-auto mb-8">
            Some customers blow through tiers and get forced into expensive upgrades.
            Others barely touch their subscription and feel guilty enough to cancel.
            Drip bridges the gap — let heavy users pay-as-they-go while keeping everyone else on predictable subscriptions.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="#early-access" class="bg-[#00B8D9] text-[#0A0A0A] px-8 py-4 rounded-md text-base font-medium hover:bg-[#00a5c4] transition-all inline-flex items-center gap-2">
              Get Early Access
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href="#problem" class="bg-transparent text-white border border-[#2A2A2A] px-8 py-4 rounded-md text-base font-medium hover:border-[#71717A] transition-colors">
              See the problem
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Agent-native tagline -->
    <div class="max-w-4xl mx-auto px-6 pb-8">
      <p class="text-center text-xl lg:text-2xl text-[#71717A] italic">
        Agent-native billing infrastructure where autonomous agents decide how software runs, spends, and scales
      </p>
    </div>

    <!-- Live Terminal Demo Section -->
    <section class="py-12">
      <div class="max-w-5xl mx-auto px-6">
        <div class="relative">
          <!-- Terminal Glow -->
          <div class="absolute -inset-1 bg-gradient-to-r from-[#00B8D9]/20 to-[#3B82F6]/20 rounded-lg blur-2xl opacity-30"></div>

          <!-- Terminal Window -->
          <div class="relative bg-[#0D0D0D] rounded-lg border border-[#1F1F1F] overflow-hidden">
            <!-- Terminal Header -->
            <div class="flex items-center gap-2 px-4 py-3 border-b border-[#1F1F1F] bg-[#111111]">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 bg-[#EF4444] rounded-full"></div>
                <div class="w-3 h-3 bg-[#F59E0B] rounded-full"></div>
                <div class="w-3 h-3 bg-[#10B981] rounded-full"></div>
              </div>
              <div class="flex-1 text-center">
                <span class="text-xs font-mono text-[#52525B]">Drip Agent — Live Demo</span>
              </div>
            </div>

            <!-- Terminal Content -->
            <div id="terminal" class="p-6 font-mono text-sm h-[320px] overflow-y-auto terminal-scroll">
              <div id="terminal-content" class="space-y-1">
                <!-- Lines will be injected here by JavaScript -->
              </div>
            </div>

            <!-- Terminal Status Bar -->
            <div class="flex items-center justify-between px-4 py-2 border-t border-[#1F1F1F] bg-[#111111]">
              <div class="flex items-center gap-4 text-xs text-[#52525B]">
                <span class="flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full pulse-dot"></span>
                  Agent Active
                </span>
                <span>|</span>
                <span>Monitoring 247 users</span>
              </div>
              <div class="text-xs text-[#52525B]">
                <span class="text-[#00B8D9]">●</span> Drip v0.8.2
              </div>
            </div>
          </div>
        </div>

        <p class="text-center text-sm text-[#71717A] mt-6 max-w-2xl mx-auto">
          Watch the agent catch a customer before the pricing cliff forces them to churn.
        </p>
      </div>
    </section>

    <!-- Before/After Comparison -->
    <section id="comparison" class="py-24 bg-[#111111]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <span class="text-[#00B8D9] text-sm font-medium tracking-wider uppercase">The Difference</span>
          <h2 class="text-3xl lg:text-4xl font-semibold tracking-tight text-white mt-4 mb-6">
            Same user. Two different billing models.
          </h2>
          <p class="text-lg text-[#A1A1AA]">
            See how Drip transforms the economics for users who don't fit neatly into subscription boxes.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
          <!-- Without Drip (Subscription) -->
          <div class="bg-[#0D0D0D] rounded-2xl p-8 border border-[#1F1F1F]">
            <div class="flex items-center gap-2 mb-6">
              <div class="w-2 h-2 bg-[#EF4444] rounded-full"></div>
              <span class="text-sm font-medium text-[#A1A1AA]">Traditional Subscription</span>
            </div>
            <!-- Calendar Grid -->
            <div class="grid grid-cols-7 gap-2 mb-6">
              {Array.from({ length: 30 }).map((_, i) => (
                <div class={`h-10 rounded-lg flex items-center justify-center text-xs font-medium ${
                  i === 5 || i === 18
                    ? 'bg-[#3B82F6]/20 text-[#3B82F6] border border-[#3B82F6]/30'
                    : 'bg-[#1F1F1F] text-[#52525B]'
                }`}>
                  {i + 1}
                </div>
              ))}
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-[#1F1F1F]">
              <div>
                <p class="text-sm text-[#71717A]">Monthly subscription</p>
                <p class="text-2xl font-semibold text-white">$29.00</p>
              </div>
              <div class="text-right">
                <p class="text-sm text-[#71717A]">Days actually used</p>
                <p class="text-2xl font-semibold text-[#EF4444]">2 days</p>
              </div>
            </div>
            <p class="text-sm text-[#EF4444] font-medium mt-4">93% wasted. User feels guilty. Likely to churn.</p>
          </div>

          <!-- With Drip (Pay-as-you-go) -->
          <div class="bg-[#0D0D0D] rounded-2xl p-8 border border-[#00B8D9]/30">
            <div class="flex items-center gap-2 mb-6">
              <div class="w-2 h-2 bg-[#10B981] rounded-full"></div>
              <span class="text-sm font-medium text-[#00B8D9]">With Drip</span>
            </div>
            <!-- Credit Gauge -->
            <div class="mb-6">
              <div class="flex items-end justify-between mb-3">
                <div>
                  <p class="text-sm text-[#71717A]">Credits consumed</p>
                  <p class="text-4xl font-semibold text-white">$2.10</p>
                </div>
                <div class="text-right">
                  <p class="text-sm text-[#71717A]">From deposit</p>
                  <p class="text-xl font-medium text-[#A1A1AA]">$5.00</p>
                </div>
              </div>
              <div class="h-3 bg-[#1F1F1F] rounded-full overflow-hidden">
                <div class="h-full w-[42%] bg-gradient-to-r from-[#10B981] to-[#00B8D9] rounded-full"></div>
              </div>
            </div>
            <!-- Receipt -->
            <div class="bg-[#111111] rounded-xl p-4 border border-[#1F1F1F]">
              <p class="text-xs font-medium text-[#52525B] mb-3">Usage breakdown</p>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-[#A1A1AA]">47 API calls</span>
                  <span class="font-medium text-white">$0.33</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[#A1A1AA]">12 data exports</span>
                  <span class="font-medium text-white">$0.04</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[#A1A1AA]">3 heavy computations</span>
                  <span class="font-medium text-white">$0.36</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[#A1A1AA]">42 min compute time</span>
                  <span class="font-medium text-white">$1.37</span>
                </div>
              </div>
            </div>
            <p class="text-sm text-[#10B981] font-medium mt-4">Paid exactly what they used. No guilt. No churn.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem: Subscription Model is Broken -->
    <section id="problem" class="py-24 border-b border-[#1F1F1F]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <span class="text-[#00B8D9] text-sm font-medium tracking-wider uppercase">The Problem</span>
          <h2 class="text-3xl lg:text-4xl font-semibold tracking-tight text-white mt-4 mb-6">
            The subscription model was built for predictable usage.
          </h2>
          <p class="text-lg text-[#A1A1AA]">
            Your customers aren't predictable. One might generate 50 reports today, 500 tomorrow, zero next week.
            Fixed tiers punish both the power user hitting limits and the occasional visitor paying for silence.
          </p>
        </div>
      </div>
    </section>

    <!-- The Problem: Pricing Cliff -->
    <section class="py-24 border-b border-[#1F1F1F]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="text-[#F59E0B] text-sm font-medium tracking-wider uppercase">Revenue Leakage</span>
            <h2 class="text-3xl lg:text-4xl font-semibold tracking-tight text-white mt-4 mb-6">
              The Pricing Cliff
            </h2>
            <p class="text-lg text-[#A1A1AA] mb-6">
              User A uses 2,900 units this month. They're on the $50 tier that includes 3,000.
            </p>
            <p class="text-lg text-[#A1A1AA] mb-6">
              User B uses 3,100. They're forced onto the $100 tier — 70% more expensive for just 200 extra units.
            </p>
            <p class="text-lg text-white font-medium">
              Every month, users like User B churn at the cliff instead of paying a fair price for their actual usage.
            </p>
          </div>

          <div class="bg-[#0D0D0D] rounded-lg border border-[#1F1F1F] p-8">
            <div class="space-y-6">
              <!-- User A -->
              <div class="pb-6 border-b border-[#1F1F1F]">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm font-medium text-[#A1A1AA]">User A</span>
                  <span class="text-xs text-[#10B981] bg-[#10B981]/10 px-2 py-1 rounded">Happy customer</span>
                </div>
                <div class="flex items-center gap-4 mb-2">
                  <div class="flex-1 h-2 bg-[#1F1F1F] rounded-full overflow-hidden">
                    <div class="h-full w-[97%] bg-[#10B981] rounded-full"></div>
                  </div>
                  <span class="text-sm font-mono text-[#71717A]">2,900 / 3,000</span>
                </div>
                <p class="text-sm text-[#71717A]">Pays $50 — uses 97% of tier. Content.</p>
              </div>

              <!-- User B -->
              <div>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm font-medium text-[#A1A1AA]">User B</span>
                  <span class="text-xs text-[#EF4444] bg-[#EF4444]/10 px-2 py-1 rounded">Churn risk</span>
                </div>
                <div class="flex items-center gap-4 mb-2">
                  <div class="flex-1 h-2 bg-[#1F1F1F] rounded-full overflow-hidden">
                    <div class="h-full w-[103%] bg-[#F59E0B] rounded-full"></div>
                  </div>
                  <span class="text-sm font-mono text-[#71717A]">3,100 / 3,000</span>
                </div>
                <p class="text-sm text-[#71717A]">Forced to $100 tier for 200 extra units. Feels ripped off.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem: Waste -->
    <section class="py-24 border-b border-[#1F1F1F]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 bg-[#0D0D0D] rounded-lg border border-[#1F1F1F] p-8">
            <div class="space-y-6">
              <div class="flex items-center justify-between">
                <span class="text-sm text-[#71717A]">User sits idle</span>
                <span class="text-xs text-[#F59E0B]">23 days</span>
              </div>
              <div class="h-24 flex items-end gap-1">
                {Array.from({ length: 30 }).map((_, i) => (
                  <div
                    class={`flex-1 rounded-t ${
                      i === 0 || i === 2 || i === 29
                        ? 'bg-[#3B82F6] h-[60%]'
                        : 'bg-[#1F1F1F] h-[10%]'
                    }`}
                  />
                ))}
              </div>
              <div class="pt-4 border-t border-[#1F1F1F]">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-[#A1A1AA]">Subscription paid</span>
                  <span class="text-lg font-semibold text-white">$49.00</span>
                </div>
                <div class="flex justify-between items-center mt-2">
                  <span class="text-sm text-[#A1A1AA]">Value received</span>
                  <span class="text-lg font-semibold text-[#EF4444]">$3.20</span>
                </div>
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <span class="text-[#EF4444] text-sm font-medium tracking-wider uppercase">The Waste Problem</span>
            <h2 class="text-3xl lg:text-4xl font-semibold tracking-tight text-white mt-4 mb-6">
              Subscription Guilt
            </h2>
            <p class="text-lg text-[#A1A1AA] mb-6">
              Light users sit on $50/mo subscriptions they barely touch. They feel guilty.
              They rationalize canceling. "I'll resubscribe when I need it."
            </p>
            <p class="text-lg text-[#A1A1AA]">
              They rarely do. The churn isn't because your product is bad — it's because the billing model doesn't fit their usage.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Innovation: Container Lifecycle Flow -->
    <section id="how-it-works" class="py-24 bg-[#111111]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <span class="text-[#00B8D9] text-sm font-medium tracking-wider uppercase">The Core Innovation</span>
          <h2 class="text-3xl lg:text-4xl font-semibold tracking-tight text-white mt-4 mb-6">
            Per-user containers that scale to zero
          </h2>
          <p class="text-lg text-[#A1A1AA]">
            You deploy once. Drip automatically creates isolated containers for each user.
            They spin up on activity. Hibernate when idle. Resume instantly.
          </p>
        </div>

        <!-- Flow Diagram -->
        <div class="max-w-5xl mx-auto">
          <div class="grid md:grid-cols-4 gap-4">
            <!-- Step 1: Developer Deploys -->
            <div class="relative">
              <div class="bg-[#0D0D0D] rounded-xl p-6 border border-[#1F1F1F] h-full">
                <div class="w-12 h-12 bg-[#00B8D9]/10 rounded-xl flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-[#00B8D9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2">1. You Deploy</h3>
                <p class="text-sm text-[#A1A1AA]">
                  Deploy your app once via BuildWithLocus. Drip handles the rest.
                </p>
              </div>
              <!-- Arrow -->
              <div class="hidden md:block absolute top-1/2 -right-4 transform -translate-y-1/2 z-10">
                <svg class="w-8 h-8 text-[#2A2A2A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>

            <!-- Step 2: User Deposits -->
            <div class="relative">
              <div class="bg-[#0D0D0D] rounded-xl p-6 border border-[#1F1F1F] h-full">
                <div class="w-12 h-12 bg-[#10B981]/10 rounded-xl flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2">2. User Deposits</h3>
                <p class="text-sm text-[#A1A1AA]">
                  Customer adds credits. Their personal container spins up instantly.
                </p>
              </div>
              <!-- Arrow -->
              <div class="hidden md:block absolute top-1/2 -right-4 transform -translate-y-1/2 z-10">
                <svg class="w-8 h-8 text-[#2A2A2A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>

            <!-- Step 3: Credits Drain -->
            <div class="relative">
              <div class="bg-[#0D0D0D] rounded-xl p-6 border border-[#1F1F1F] h-full">
                <div class="w-12 h-12 bg-[#3B82F6]/10 rounded-xl flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-white mb-2">3. Usage Tracked</h3>
                <p class="text-sm text-[#A1A1AA]">
                  Every API call, every compute unit. Metered in real-time.
                </p>
              </div>
              <!-- Arrow -->
              <div class="hidden md:block absolute top-1/2 -right-4 transform -translate-y-1/2 z-10">
                <svg class="w-8 h-8 text-[#2A2A2A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>

            <!-- Step 4: Hibernate/Resume -->
            <div class="bg-[#0D0D0D] rounded-xl p-6 border border-[#1F1F1F]">
              <div class="w-12 h-12 bg-[#F59E0B]/10 rounded-xl flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-white mb-2">4. Auto-Lifecycle</h3>
              <p class="text-sm text-[#A1A1AA]">
                Credits hit zero? Container hibernates. Top up? Resumes instantly. State preserved.
              </p>
            </div>
          </div>

          <!-- Bottom Callout -->
          <div class="mt-12 bg-gradient-to-r from-[#00B8D9]/10 to-[#3B82F6]/10 rounded-xl border border-[#00B8D9]/20 p-8 text-center">
            <p class="text-lg text-[#A1A1AA]">
              <span class="text-white font-medium">Users pay only for compute they actually consume.</span>
              No monthly subscription waste. No idle infrastructure costs. No churn from users who forgot to cancel.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- The Solution -->
    <section id="solution" class="py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <span class="text-[#00B8D9] text-sm font-medium tracking-wider uppercase">The Solution</span>
          <h2 class="text-3xl lg:text-4xl font-semibold tracking-tight text-white mt-4 mb-6">
            Drip sits between your tiers and their usage
          </h2>
          <p class="text-lg text-[#A1A1AA]">
