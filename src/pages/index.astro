---
// Drip Landing Page
// Pay-as-you-go compute infrastructure for developers
// Positioning: "Turn your app into a utility. Users pay for compute, not calendar months."
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Drip — Turn your app into a utility. Users pay for compute, not calendar months. Pay-as-you-go infrastructure for developers." />
		<title>Drip — Pay for Compute. Not for Calendar Months.</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="font-sans antialiased text-slate-900 bg-white">
		<!-- Header -->
		<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/50">
			<nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
						<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2c.552 0 1 .448 1 1v2.101a7.002 7.002 0 011.913 1.5l1.792-1.035c.478-.276 1.09-.112 1.366.366s.112 1.09-.366 1.366l-1.792 1.035a7.002 7.002 0 010 3.336l1.792 1.035c.478.276.642.888.366 1.366s-.888.642-1.366.366l-1.792-1.035A7.002 7.002 0 0113 17.899V20c0 .552-.448 1-1 1s-1-.448-1-1v-2.101a7.002 7.002 0 01-1.913-1.5l-1.792 1.035c-.478.276-1.09.112-1.366-.366s-.112-1.09.366-1.366l1.792-1.035a7.002 7.002 0 010-3.336l-1.792-1.035c-.478-.276-.642-.888-.366-1.366s.888-.642 1.366-.366l1.792 1.035A7.002 7.002 0 0111 6.101V4c0-.552.448-1 1-1z"/>
						</svg>
					</div>
					<span class="font-semibold text-lg tracking-tight">drip</span>
				</div>
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
					<a href="#how-it-works" class="hover:text-slate-900 transition-colors">How it works</a>
					<a href="#for-developers" class="hover:text-slate-900 transition-colors">For developers</a>
					<a href="#pricing" class="hover:text-slate-900 transition-colors">Pricing</a>
					<a href="#docs" class="hover:text-slate-900 transition-colors">Docs</a>
				</div>
				<div class="flex items-center gap-4">
					<a href="https://github.com/0xshae/drip" class="text-slate-600 hover:text-slate-900 transition-colors">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
					</a>
					<a href="#docs" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
						Start building
					</a>
				</div>
			</nav>
		</header>

		<!-- Hero Section -->
		<section class="pt-32 pb-20 lg:pt-40 lg:pb-32">
			<div class="max-w-7xl mx-auto px-6">
				<!-- Headline -->
				<div class="max-w-4xl mx-auto text-center mb-16">
					<h1 class="text-5xl lg:text-7xl font-semibold tracking-tight text-slate-900 leading-[1.1] mb-6">
						Pay for compute.<br/>Not for calendar months.
					</h1>
					<p class="text-xl text-slate-600 leading-relaxed max-w-2xl mx-auto mb-8">
						Drip turns your app into a pay-as-you-drink utility. Users deposit credits,
						their container runs, credits drain on actual usage. When they're out — the
						container hibernates, state intact. When they top up — it resumes instantly.
						No subscriptions. No waste. No churn from people who forgot to cancel.
					</p>
					<div class="flex flex-wrap justify-center gap-4">
						<a href="#docs" class="bg-indigo-600 text-white px-8 py-4 rounded-xl text-base font-medium hover:bg-indigo-700 transition-all hover:shadow-lg hover:shadow-indigo-500/25 inline-flex items-center gap-2">
							Add Drip to your app
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
							</svg>
						</a>
						<a href="#how-it-works" class="bg-white text-slate-700 border border-slate-200 px-8 py-4 rounded-xl text-base font-medium hover:bg-slate-50 transition-colors">
							See how it works
						</a>
					</div>
					<p class="text-sm text-slate-500 mt-6">
						<a href="#for-developers" class="inline-flex items-center gap-1 hover:text-slate-700 transition-colors">
							Building a product? Add Drip to your app in 5 minutes.
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
							</svg>
						</a>
					</p>
				</div>

				<!-- Hero Visual: Before/After Comparison -->
				<div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
					<!-- Without Drip (Subscription) -->
					<div class="bg-slate-50 rounded-2xl p-8 border border-slate-200">
						<div class="flex items-center gap-2 mb-6">
							<div class="w-2 h-2 bg-red-500 rounded-full"></div>
							<span class="text-sm font-medium text-slate-600">Without Drip</span>
						</div>
						<!-- Calendar Grid -->
						<div class="grid grid-cols-7 gap-2 mb-6">
							{Array.from({ length: 30 }).map((_, i) => (
								<div class={`h-10 rounded-lg flex items-center justify-center text-xs font-medium ${
									i === 5 || i === 18
										? 'bg-indigo-100 text-indigo-700 border-2 border-indigo-300'
										: 'bg-slate-200 text-slate-400'
								}`}>
									{i + 1}
								</div>
							))}
						</div>
						<div class="flex items-center justify-between pt-4 border-t border-slate-200">
							<div>
								<p class="text-sm text-slate-500">Monthly subscription</p>
								<p class="text-2xl font-semibold text-slate-900">$29.00</p>
							</div>
							<div class="text-right">
								<p class="text-sm text-slate-500">Days actually used</p>
								<p class="text-2xl font-semibold text-red-600">2 days</p>
							</div>
						</div>
						<p class="text-sm text-red-600 font-medium mt-4">93% wasted</p>
					</div>

					<!-- With Drip (Pay-as-you-go) -->
					<div class="bg-indigo-50 rounded-2xl p-8 border border-indigo-200">
						<div class="flex items-center gap-2 mb-6">
							<div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
							<span class="text-sm font-medium text-indigo-900">With Drip</span>
						</div>
						<!-- Credit Gauge -->
						<div class="mb-6">
							<div class="flex items-end justify-between mb-3">
								<div>
									<p class="text-sm text-indigo-600/70">Credits consumed</p>
									<p class="text-4xl font-semibold text-indigo-900">$2.10</p>
								</div>
								<div class="text-right">
									<p class="text-sm text-indigo-600/70">From deposit</p>
									<p class="text-xl font-medium text-indigo-700">$5.00</p>
								</div>
							</div>
							<div class="h-3 bg-indigo-100 rounded-full overflow-hidden">
								<div class="h-full w-[42%] bg-gradient-to-r from-emerald-400 to-emerald-500 rounded-full"></div>
							</div>
						</div>
						<!-- Receipt -->
						<div class="bg-white rounded-xl p-4 border border-indigo-100">
							<p class="text-xs font-medium text-slate-500 mb-3">Compute breakdown</p>
							<div class="space-y-2 text-sm">
								<div class="flex justify-between">
									<span class="text-slate-600">47 Exa searches</span>
									<span class="font-medium text-slate-900">$0.33</span>
								</div>
								<div class="flex justify-between">
									<span class="text-slate-600">12 Firecrawl scrapes</span>
									<span class="font-medium text-slate-900">$0.04</span>
								</div>
								<div class="flex justify-between">
									<span class="text-slate-600">3 Claude syntheses</span>
									<span class="font-medium text-slate-900">$0.36</span>
								</div>
								<div class="flex justify-between">
									<span class="text-slate-600">42 min compute</span>
									<span class="font-medium text-slate-900">$1.37</span>
								</div>
							</div>
						</div>
						<p class="text-sm text-emerald-600 font-medium mt-4">Paid exactly what they used</p>
					</div>
				</div>
			</div>
		</section>

		<!-- How It Works (For Users) -->
		<section id="how-it-works" class="py-24 bg-slate-50/50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center max-w-2xl mx-auto mb-16">
					<h2 class="text-4xl font-semibold tracking-tight text-slate-900 mb-4">Software that works like electricity</h2>
					<p class="text-lg text-slate-600">Users pay for what they draw. Not a flat fee for the wires.</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
					<!-- Step 1: Deposit -->
					<div class="bg-white rounded-2xl p-8 border border-slate-200">
						<div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-6">
							<svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-slate-900 mb-2">Deposit</h3>
						<p class="text-slate-600 text-sm leading-relaxed">
							Deposit USDC. That's your credit balance — your fuel.
						</p>
					</div>

					<!-- Step 2: Run -->
					<div class="bg-white rounded-2xl p-8 border border-slate-200">
						<div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-6">
							<svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-slate-900 mb-2">Run</h3>
						<p class="text-slate-600 text-sm leading-relaxed">
							Open the app. BuildWithLocus spins your personal container. Credits drain based on actual compute.
						</p>
					</div>

					<!-- Step 3: Hibernate -->
					<div class="bg-white rounded-2xl p-8 border border-slate-200">
						<div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center mb-6">
							<svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-slate-900 mb-2">Hibernate</h3>
						<p class="text-slate-600 text-sm leading-relaxed">
							Credits hit zero. The container hibernates cleanly. Your data, history, and preferences are preserved.
						</p>
					</div>

					<!-- Step 4: Resume -->
					<div class="bg-white rounded-2xl p-8 border border-slate-200">
						<div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center mb-6">
							<svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-slate-900 mb-2">Resume</h3>
						<p class="text-slate-600 text-sm leading-relaxed">
							Top up any amount. The container resumes exactly where it left off. No re-onboarding. Instant.
						</p>
					</div>
				</div>

				<p class="text-center text-sm text-slate-500 mt-10 max-w-2xl mx-auto">
					The AI agent running underneath monitors your balance in real time, warns you before you run out,
					and makes smart tradeoffs to extend your runtime. <span class="text-slate-700">It's the engine. You don't need to think about it.</span>
				</p>
			</div>
		</section>

		<!-- For Developers Section -->
		<section id="for-developers" class="py-24">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center max-w-2xl mx-auto mb-16">
					<h2 class="text-4xl font-semibold tracking-tight text-slate-900 mb-4">For developers</h2>
					<p class="text-lg text-slate-600">Plug Drip into your BuildWithLocus app. We handle the metering, containers, and user communication. You ship the product.</p>
				</div>

				<div class="grid lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
					<!-- What you get -->
					<div>
						<h3 class="text-lg font-semibold text-slate-900 mb-6">What you get out of the box</h3>
						<ul class="space-y-4">
							<li class="flex items-start gap-3">
								<div class="w-5 h-5 bg-indigo-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
									<svg class="w-3 h-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
									</svg>
								</div>
								<div>
									<p class="font-medium text-slate-900">Per-user isolated containers via BuildWithLocus</p>
									<p class="text-sm text-slate-600">One container per customer, zero shared state, automatic teardown</p>
								</div>
							</li>
							<li class="flex items-start gap-3">
								<div class="w-5 h-5 bg-indigo-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
									<svg class="w-3 h-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
									</svg>
								</div>
								<div>
									<p class="font-medium text-slate-900">Credit metering with @drip.meter()</p>
									<p class="text-sm text-slate-600">Decorate any function, credits drain automatically when it runs</p>
								</div>
							</li>
							<li class="flex items-start gap-3">
								<div class="w-5 h-5 bg-indigo-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
									<svg class="w-3 h-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
									</svg>
								</div>
								<div>
									<p class="font-medium text-slate-900">Container lifecycle management</p>
									<p class="text-sm text-slate-600">Hibernation at $0, instant restore on top-up, state preserved in Postgres</p>
								</div>
							</li>
							<li class="flex items-start gap-3">
								<div class="w-5 h-5 bg-indigo-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
									<svg class="w-3 h-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
									</svg>
								</div>
								<div>
									<p class="font-medium text-slate-900">Proactive user communication via AgentMail</p>
									<p class="text-sm text-slate-600">Low-credit warnings, weekly receipts, and recharge prompts, automatic</p>
								</div>
							</li>
							<li class="flex items-start gap-3">
								<div class="w-5 h-5 bg-indigo-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
									<svg class="w-3 h-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
									</svg>
								</div>
								<div>
									<p class="font-medium text-slate-900">PayWithLocus checkout embedded</p>
									<p class="text-sm text-slate-600">USDC credit packs, one API call to accept payment</p>
								</div>
							</li>
						</ul>
					</div>

					<!-- Code Example -->
					<div>
						<h3 class="text-lg font-semibold text-slate-900 mb-6">5-minute integration</h3>
						<div class="bg-slate-950 rounded-xl overflow-hidden">
							<div class="flex items-center gap-2 px-4 py-3 border-b border-slate-800">
								<div class="flex gap-1.5">
									<div class="w-3 h-3 bg-red-500 rounded-full"></div>
									<div class="w-3 h-3 bg-amber-500 rounded-full"></div>
									<div class="w-3 h-3 bg-emerald-500 rounded-full"></div>
								</div>
								<div class="flex-1 text-center text-xs text-slate-500 font-mono">app.py</div>
							</div>
							<div class="p-4 font-mono text-sm overflow-x-auto">
								<div class="text-slate-500">from drip import DripClient, DripConfig</div>
								<div class="text-slate-300"></div>
								<div class="text-slate-300">client = <span class="text-blue-400">DripClient</span>(<span class="text-blue-400">DripConfig</span>(</div>
								<div class="text-slate-300 pl-4">locus_api_key=<span class="text-emerald-400">"claw_dev_..."</span>,</div>
								<div class="text-slate-300 pl-4">bwl_api_key=<span class="text-emerald-400">"claw_dev_..."</span>,</div>
								<div class="text-slate-300">))</div>
								<div class="text-slate-300"></div>
								<div class="text-slate-500"># Decorate any function. Credits drain when it runs.</div>
								<div class="text-slate-300"><span class="text-indigo-400">@client.meter</span>(cost=<span class="text-amber-400">0.007</span>, event=<span class="text-emerald-400">"search"</span>)</div>
								<div class="text-slate-300"><span class="text-purple-400">async def</span> <span class="text-blue-400">search</span>(query: <span class="text-blue-400">str</span>, user_id: <span class="text-blue-400">str</span>):</div>
								<div class="text-slate-300 pl-4"><span class="text-purple-400">return await</span> your_search_api(query)</div>
								<div class="text-slate-300"></div>
								<div class="text-slate-500"># Provision a user (spins their container, sets up wallet)</div>
								<div class="text-slate-300"><span class="text-purple-400">await</span> client.provision_user(</div>
								<div class="text-slate-300 pl-4">user_id=<span class="text-emerald-400">"user_abc"</span>,</div>
								<div class="text-slate-300 pl-4">email=<span class="text-emerald-400">"user@example.com"</span>,</div>
								<div class="text-slate-300 pl-4">initial_balance=<span class="text-amber-400">5.0</span>,</div>
								<div class="text-slate-300">)</div>
								<div class="text-slate-300"></div>
								<div class="text-slate-400"># Drip handles everything else:</div>
								<div class="text-slate-500"># ✓ balance polling every 60s</div>
								<div class="text-slate-500"># ✓ container hibernation at $0</div>
								<div class="text-slate-500"># ✓ instant restore on top-up</div>
								<div class="text-slate-500"># ✓ AgentMail low-credit warnings</div>
								<div class="text-slate-500"># ✓ itemized usage receipts</div>
							</div>
						</div>
					</div>
				</div>

				<div class="text-center mt-12">
					<a href="https://pypi.org/project/drip-sdk" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition-colors">
						Install drip-sdk
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
						</svg>
					</a>
