---
// Drip Landing Page
// Apple-minimalist, Locus-inspired, agent-first design
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Drip — Software that runs itself within your budget. The first agent-native SaaS billing layer." />
		<title>Drip — Software That Runs Within Your Budget</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="font-sans antialiased text-slate-900 bg-white">
		<!-- Header -->
		<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/50">
			<nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
						<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
						</svg>
					</div>
					<span class="font-semibold text-lg tracking-tight">drip</span>
				</div>
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
					<a href="#how-it-works" class="hover:text-slate-900 transition-colors">How it works</a>
					<a href="#demo" class="hover:text-slate-900 transition-colors">Live Demo</a>
					<a href="#pricing" class="hover:text-slate-900 transition-colors">Pricing</a>
				</div>
				<div class="flex items-center gap-4">
					<a href="https://github.com/0xshae/drip" class="text-slate-600 hover:text-slate-900 transition-colors">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
					</svg>
					</a>
					<a href="#demo" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
						Try Demo
					</a>
				</div>
			</nav>
		</header>

		<!-- Hero Section -->
		<section class="pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden">
			<div class="max-w-7xl mx-auto px-6">
				<div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div class="space-y-8">
						<div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 border border-indigo-100 rounded-full">
							<span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
							<span class="text-xs font-medium text-indigo-900">Agent is running</span>
						</div>
						<h1 class="text-5xl lg:text-7xl font-semibold tracking-tight text-slate-900 leading-[1.1]">
							Software that runs itself within your budget
						</h1>
						<p class="text-xl text-slate-600 leading-relaxed max-w-xl">
							Drip is the first agent-native SaaS billing layer. An AI agent manages your resource lifecycle in real time, making decisions a billing form can't.
						</p>
						<div class="flex flex-wrap gap-4">
							<a href="#demo" class="bg-indigo-600 text-white px-8 py-4 rounded-xl text-base font-medium hover:bg-indigo-700 transition-all hover:shadow-lg hover:shadow-indigo-500/25">
								Start with 20 USDC free
							</a>
							<a href="#how-it-works" class="bg-white text-slate-700 border border-slate-200 px-8 py-4 rounded-xl text-base font-medium hover:bg-slate-50 transition-colors">
								Watch the agent think
							</a>
						</div>
						<p class="text-sm text-slate-500 flex items-center gap-2">
							<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
							</svg>
							No credit card required. Runs on BuildWithLocus.
						</p>
					</div>

					<!-- Live Agent Demo Card -->
					<div class="relative">
						<div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-indigo-500 rounded-2xl blur-2xl opacity-20"></div>
						<div class="relative bg-white border border-slate-200 rounded-2xl shadow-2xl shadow-slate-900/10 overflow-hidden">
							<!-- Status Bar -->
							<div class="flex items-center justify-between px-4 py-3 border-b border-slate-100 bg-slate-50/50">
								<div class="flex items-center gap-3">
									<div class="flex items-center gap-2">
										<span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
										<span class="text-xs font-medium text-slate-700">Active</span>
									</div>
									<span class="text-slate-300">|</span>
									<span class="text-xs text-slate-500">user_8f2a1</span>
								</div>
								<div class="flex items-center gap-2 text-xs text-slate-500">
									<span>Running on</span>
									<span class="font-medium text-slate-700">BWL</span>
								</div>
							</div>

							<!-- Credit Meter -->
							<div class="p-6 border-b border-slate-100">
								<div class="flex items-end justify-between mb-4">
									<div>
										<p class="text-sm text-slate-500 mb-1">Balance</p>
										<p class="text-4xl font-semibold text-slate-900">0.45</p>
										<p class="text-sm text-slate-500">USDC</p>
									</div>
									<div class="text-right">
										<p class="text-sm text-amber-600 font-medium mb-1">Low Credit</p>
										<p class="text-xs text-slate-500">~22 min remaining</p>
									</div>
								</div>
								<div class="h-2 bg-slate-100 rounded-full overflow-hidden">
									<div class="h-full w-[9%] bg-gradient-to-r from-amber-400 to-amber-500 rounded-full"></div>
								</div>
								<div class="flex justify-between mt-2 text-xs text-slate-400">
									<span>0</span>
									<span>5.00 USDC</span>
								</div>
							</div>

							<!-- Live Agent Logs -->
							<div class="p-4 bg-slate-950">
								<div class="flex items-center justify-between mb-3">
									<p class="text-xs font-medium text-slate-400">Live Agent Logs</p>
									<div class="flex items-center gap-1.5">
										<span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
										<span class="text-xs text-slate-500">LIVE</span>
									</div>
								</div>
								<div class="space-y-2 font-mono text-xs">
									<div class="text-slate-400">
										<span class="text-slate-500">[14:02]</span>
										<span class="text-indigo-400">Drip:</span> checking balance... 0.45 USDC remaining
									</div>
									<div class="text-slate-400">
										<span class="text-slate-500">[14:02]</span>
										<span class="text-indigo-400">Drip:</span> burn rate 0.02/min → estimated 22 min of life
									</div>
									<div class="text-amber-400/90">
										<span class="text-slate-500">[14:03]</span>
										<span class="text-indigo-400">Drip:</span> budget tight — crawling 2 sources instead of 5
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- How It Works Section -->
		<section id="how-it-works" class="py-24 bg-slate-50/50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center max-w-2xl mx-auto mb-16">
					<h2 class="text-4xl font-semibold tracking-tight text-slate-900 mb-4">How the agent works</h2>
					<p class="text-lg text-slate-600">Unlike traditional billing, Drip makes intelligent decisions in real time.</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
					<!-- Step 1 -->
					<div class="group">
						<div class="bg-white rounded-2xl p-8 border border-slate-200 h-full transition-all hover:shadow-lg hover:shadow-slate-900/5 hover:border-indigo-200">
							<div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-6 group-hover:bg-indigo-100 transition-colors">
								<svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
								</svg>
							</div>
							<div class="flex items-center gap-3 mb-3">
								<span class="text-sm font-medium text-indigo-600">01</span>
								<h3 class="text-lg font-semibold text-slate-900">Deposit</h3>
							</div>
							<p class="text-slate-600 text-sm leading-relaxed">
								Deposit USDC via PayWithLocus, specify your research topic, and the agent spins up your container.
							</p>
						</div>
					</div>

					<!-- Step 2 -->
					<div class="group">
						<div class="bg-white rounded-2xl p-8 border border-slate-200 h-full transition-all hover:shadow-lg hover:shadow-slate-900/5 hover:border-indigo-200">
							<div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-6 group-hover:bg-indigo-100 transition-colors">
								<svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
								</svg>
							</div>
							<div class="flex items-center gap-3 mb-3">
								<span class="text-sm font-medium text-indigo-600">02</span>
								<h3 class="text-lg font-semibold text-slate-900">Monitor</h3>
							</div>
							<p class="text-slate-600 text-sm leading-relaxed">
								The agent watches your credits in real time, calculating burn rate and making tradeoffs under budget pressure.
							</p>
						</div>
					</div>

					<!-- Step 3 -->
					<div class="group">
						<div class="bg-white rounded-2xl p-8 border border-slate-200 h-full transition-all hover:shadow-lg hover:shadow-slate-900/5 hover:border-indigo-200">
							<div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center mb-6 group-hover:bg-amber-100 transition-colors">
								<svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
								</svg>
							</div>
							<div class="flex items-center gap-3 mb-3">
								<span class="text-sm font-medium text-amber-600">03</span>
								<h3 class="text-lg font-semibold text-slate-900">Think</h3>
							</div>
							<p class="text-slate-600 text-sm leading-relaxed">
								When credits run low, it warns you, reduces quality to extend runtime, and gracefully manages scarcity.
							</p>
						</div>
					</div>

					<!-- Step 4 -->
					<div class="group">
						<div class="bg-white rounded-2xl p-8 border border-slate-200 h-full transition-all hover:shadow-lg hover:shadow-slate-900/5 hover:border-indigo-200">
							<div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center mb-6 group-hover:bg-emerald-100 transition-colors">
								<svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
								</svg>
							</div>
							<div class="flex items-center gap-3 mb-3">
								<span class="text-sm font-medium text-emerald-600">04</span>
								<h3 class="text-lg font-semibold text-slate-900">Restore</h3>
							</div>
							<p class="text-slate-600 text-sm leading-relaxed">
								Top up → Agent auto-restores container, picks up where it left off. State preserved in Postgres.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- The Agent Difference Section -->
		<section class="py-24">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center max-w-2xl mx-auto mb-16">
					<h2 class="text-4xl font-semibold tracking-tight text-slate-900 mb-4">The agent difference</h2>
					<p class="text-lg text-slate-600">Not a billing form. Not a cron job. An agent that thinks.</p>
				</div>

				<div class="grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
					<!-- Traditional -->
					<div class="bg-slate-50 rounded-2xl p-8 border border-slate-200">
						<div class="flex items-center gap-3 mb-6">
							<div class="w-10 h-10 bg-slate-200 rounded-lg flex items-center justify-center">
								<svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
								</svg>
							</div>
							<h3 class="text-lg font-semibold text-slate-700">Traditional Billing</h3>
						</div>
						<ul class="space-y-4">
							<li class="flex items-start gap-3 text-slate-600">
								<svg class="w-5 h-5 text-slate-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
								</svg>
								<span>Static subscription — same price, usage doesn't matter</span>
							</li>
							<li class="flex items-start gap-3 text-slate-600">
								<svg class="w-5 h-5 text-slate-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
								</svg>
								<span>Binary on/off — service stops when payment fails</span>
							</li>
							<li class="flex items-start gap-3 text-slate-600">
								<svg class="w-5 h-5 text-slate-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
								</svg>
								<span>Human-triggered warnings — "You have 3 days to renew"</span>
							</li>
							<li class="flex items-start gap-3 text-slate-600">
								<svg class="w-5 h-5 text-slate-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
								</svg>
								<span>No budget intelligence — waste credits or hit a wall</span>
							</li>
						</ul>
					</div>

					<!-- Drip -->
					<div class="bg-indigo-50 rounded-2xl p-8 border border-indigo-200">
						<div class="flex items-center gap-3 mb-6">
							<div class="w-10 h-10 bg-indigo-600 rounded-lg flex items-center justify-center">
								<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
								</svg>
							</div>
							<h3 class="text-lg font-semibold text-indigo-900">Drip Agent</h3>
						</div>
						<ul class="space-y-4">
							<li class="flex items-start gap-3 text-indigo-900">
								<svg class="w-5 h-5 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
								</svg>
								<span>Dynamic credits — pay for actual usage, proportional to value</span>
							</li>
							<li class="flex items-start gap-3 text-indigo-900">
								<svg class="w-5 h-5 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
								</svg>
								<span>Graceful scaling — hibernates at $0, instantly restores on top-up</span>
							</li>
							<li class="flex items-start gap-3 text-indigo-900">
								<svg class="w-5 h-5 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
								</svg>
								<span>AI-proactive warnings — "22 min remaining, reducing quality to extend runtime"</span>
							</li>
							<li class="flex items-start gap-3 text-indigo-900">
								<svg class="w-5 h-5 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
								</svg>
								<span>Budget-aware tradeoffs — manages scarcity, not just alerts on it</span>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Live Demo Section -->
		<section id="demo" class="py-24 bg-slate-900">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center max-w-2xl mx-auto mb-16">
					<h2 class="text-4xl font-semibold tracking-tight text-white mb-4">Watch the agent think</h2>
					<p class="text-lg text-slate-400">Every decision, every tradeoff, every dollar — visible in real time.</p>
				</div>

				<div class="max-w-4xl mx-auto">
					<div class="relative">
						<div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-2xl blur-2xl opacity-30"></div>
						<div class="relative bg-slate-950 rounded-2xl border border-slate-800 overflow-hidden">
							<!-- Terminal Header -->
							<div class="flex items-center gap-2 px-4 py-3 border-b border-slate-800 bg-slate-900/50">
								<div class="flex gap-1.5">
									<div class="w-3 h-3 bg-red-500 rounded-full"></div>
									<div class="w-3 h-3 bg-amber-500 rounded-full"></div>
									<div class="w-3 h-3 bg-emerald-500 rounded-full"></div>
								</div>
								<div class="flex-1 text-center text-xs text-slate-500 font-mono">agent@drip:~/workspace</div>
							</div>

							<!-- Terminal Content -->
							<div class="p-6 font-mono text-sm space-y-3">
								<div class="text-slate-500">$ drip agent --status user_8f2a1</div>
								<div class="text-slate-300 pb-2 border-b border-slate-800">
									<span class="text-emerald-400">●</span> Active | Container: healthy | Uptime: 2h 14m | Credits: 0.45 USDC
								</div>

								<div class="text-slate-500 mt-4">$ drip agent --logs --follow</div>
								<div class="space-y-1.5 text-slate-400">
									<div><span class="text-slate-600">[13:58:14]</span> <span class="text-indigo-400">Drip:</span> completed research cycle #47</div>
									<div><span class="text-slate-600">[13:58:14]</span> <span class="text-indigo-400">Drip:</span> deducted 0.05 USDC (1 Exa search + 3 Firecrawl pages + Claude synthesis)</div>
									<div><span class="text-slate-600">[14:02:00]</span> <span class="text-indigo-400">Drip:</span> checking balance... 0.45 USDC remaining</div>
									<div><span class="text-slate-600">[14:02:01]</span> <span class="text-indigo-400">Drip:</span> burn rate 0.02/min → estimated 22 min of life</div>
									<div><span class="text-slate-600">[14:02:01]</span> <span class="text-amber-400">Drip:</span> ⚠ BUDGET TIGHT — reducing crawl from 5 sources to 2 sources to extend runtime</div>
									<div><span class="text-slate-600">[14:02:02]</span> <span class="text-amber-400">Drip:</span> sent low-credit warning via AgentMail to user@example.com</div>
